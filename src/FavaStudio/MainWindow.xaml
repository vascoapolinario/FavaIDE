<Window x:Class="FavaStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:FavaStudio.Converters"
        Title="Fava Studio" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:FileNameConverter x:Key="FileNameConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Toolbar                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel LastChildFill="False">

                <!-- App title -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="◈" FontSize="18" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Fava Studio" FontSize="15" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Left" Width="1"
                           Fill="{StaticResource BorderBrush}" Margin="2,4"/>

                <!-- File operations -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Open Project" Command="{Binding OpenProjectCommand}"
                            ToolTip="Open a folder containing .fava source files"/>
                    <Button Content="New File"     Command="{Binding NewFileCommand}"
                            ToolTip="Create a new .fava source file"/>
                    <Button Content="Save"         Command="{Binding SaveFileCommand}"
                            ToolTip="Save the currently open file"/>
                </StackPanel>

                <Rectangle DockPanel.Dock="Left" Width="1"
                           Fill="{StaticResource BorderBrush}" Margin="6,4"/>

                <!-- Run operations -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="▶  Run"
                            Command="{Binding RunCurrentCommand}"
                            Style="{StaticResource AccentButton}"
                            ToolTip="Compile and run the currently open file"/>
                    <Button Content="Run All Tests" Command="{Binding RunAllTestsCommand}"
                            ToolTip="Execute all test cases from the configured test folders"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Main layout: sidebar + content                                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────── -->
            <!-- Sidebar: Project Explorer                               -->
            <!-- ─────────────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Sidebar header -->
                    <Border DockPanel.Dock="Top"
                            Padding="10,7,8,7"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{StaticResource BgPanelAltBrush}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="+"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding NewFileCommand}"
                                    ToolTip="New File"
                                    Width="22" Height="22" Padding="0" FontSize="15"
                                    VerticalContentAlignment="Center"/>
                            <TextBlock Text="PROJECT EXPLORER"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Open-project button anchored to bottom -->
                    <Button DockPanel.Dock="Bottom"
                            Content="Open Project Folder…"
                            Command="{Binding OpenProjectCommand}"
                            Margin="8,6"
                            ToolTip="Select a folder — all .fava files inside will appear here"/>

                    <!-- File list (filename only; tooltip shows full path) -->
                    <ListBox ItemsSource="{Binding ProjectFiles}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="4,4,4,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="› " Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"
                                               ToolTip="{Binding}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>

            <!-- Column splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="{StaticResource BorderBrush}"/>

            <!-- ─────────────────────────────────────────────────────── -->
            <!-- Content area: tabs                                      -->
            <!-- ─────────────────────────────────────────────────────── -->
            <TabControl Grid.Column="2">

                <!-- ══════ EDITOR TAB ══════ -->
                <TabItem Header="  Editor  ">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="130" MinHeight="40"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Current-file path bar -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BgPanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="10,5">
                            <TextBlock Text="{Binding CurrentFileName}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                        </Border>

                        <!-- Code editor -->
                        <avalonedit:TextEditor Grid.Row="1"
                                               x:Name="Editor"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               ShowLineNumbers="True"
                                               Background="{StaticResource BgMainBrush}"
                                               Foreground="{StaticResource TextMainBrush}"/>

                        <!-- Row splitter -->
                        <GridSplitter Grid.Row="2" Height="5"
                                      HorizontalAlignment="Stretch"
                                      ResizeDirection="Rows"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- Errors / diagnostics panel -->
                        <Border Grid.Row="3"
                                Background="{StaticResource BgPanelBrush}">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Padding="10,6"
                                        Background="{StaticResource BgPanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,1,0,1">
                                    <TextBlock Text="{Binding DiagnosticsHeader}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </Border>
                                <ListBox ItemsSource="{Binding Diagnostics}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Margin="4,2">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="⚠ "  Foreground="Orange"/>
                                                <Run Text="{Binding Severity}"  Foreground="Orange"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding Line}"   Foreground="{StaticResource TextMainBrush}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Column}" Foreground="{StaticResource TextMainBrush}"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding Message}" Foreground="{StaticResource TextMainBrush}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- Inline status -->
                        <Border Grid.Row="4"
                                Background="{StaticResource BgPanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="10,5">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{Binding StatusColor}"
                                       FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ══════ TESTS TAB ══════ -->
                <TabItem Header="  Tests  ">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tests toolbar -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BgPanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶  Run All Tests"
                                        Command="{Binding RunAllTestsCommand}"
                                        Style="{StaticResource AccentButton}"
                                        ToolTip="Run every test case in the configured folders"/>
                                <Button Content="Run Selected"
                                        Command="{Binding RunSelectedTestsCommand}"
                                        ToolTip="Re-run only the test case highlighted in the list"/>
                                <CheckBox Content="Show Output"
                                          IsChecked="{Binding ShowTestOutput}"
                                          Margin="14,0,0,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Display raw compiler output alongside each test result"/>
                            </StackPanel>
                        </Border>

                        <!-- Test results grid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TestResults}"
                                  AutoGenerateColumns="False"
                                  SelectedItem="{Binding SelectedTestResult}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Test Name" Binding="{Binding Name}"    Width="200"/>
                                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"  Width="100"/>
                                <DataGridTextColumn Header="Details"   Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Test summary bar -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BgPanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="10,5">
                            <TextBlock Text="{Binding TestSummary}"
                                       Foreground="{Binding StatusColor}"
                                       FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ══════ CONSOLE TAB ══════ -->
                <TabItem Header="  Console  ">
                    <TextBox x:Name="ConsoleBox"
                             Text="{Binding ConsoleOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="{StaticResource BgMainBrush}"
                             Foreground="{StaticResource TextMainBrush}"
                             BorderThickness="0"
                             Padding="10"
                             VerticalScrollBarVisibility="Auto"/>
                </TabItem>

                <!-- ══════ SETTINGS TAB ══════ -->
                <TabItem Header="  ⚙ Settings  ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="620">

                            <!-- Page header -->
                            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Configure paths and preferences. Use the Browse buttons to pick files and folders from your file system."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,24"/>

                            <!-- ── JAVA section ── -->
                            <TextBlock Text="JAVA" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,12" Margin="0,0,0,22"
                                    Background="{StaticResource BgPanelBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Java Executable"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding Settings.JavaPath}"
                                             ToolTip="Path to java.exe, or 'java' if Java is already on your PATH"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Content="Browse…"
                                            Command="{Binding BrowseJavaPathCommand}"
                                            ToolTip="Open file browser to locate java.exe"
                                            Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="Tip: use 'java' here if java.exe is already in your system PATH."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- ── COMPILER section ── -->
                            <TextBlock Text="COMPILER" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,12" Margin="0,0,0,22"
                                    Background="{StaticResource BgPanelBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Compiler Root"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding Settings.CompilerRoot}"
                                             ToolTip="Root folder of your FavaCompiler repository"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Content="Browse…"
                                            Command="{Binding BrowseCompilerRootCommand}"
                                            ToolTip="Open folder browser to locate the FavaCompiler folder"
                                            Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="ANTLR Jar"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding Settings.AntlrJar}"
                                             ToolTip="Full path to antlr-4.x-complete.jar"/>
                                    <Button Grid.Row="2" Grid.Column="2"
                                            Content="Browse…"
                                            Command="{Binding BrowseAntlrJarCommand}"
                                            ToolTip="Open file browser to locate the ANTLR .jar file"
                                            Margin="6,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- ── TEST FOLDERS section ── -->
                            <TextBlock Text="TEST FOLDERS" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,12" Margin="0,0,0,28"
                                    Background="{StaticResource BgPanelBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Inputs Folder"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Text="{Binding Settings.InputsDir}"
                                             ToolTip="Folder that contains .fava test input files"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Content="Browse…"
                                            Command="{Binding BrowseInputsDirCommand}"
                                            ToolTip="Open folder browser to select the test inputs folder"
                                            Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Outputs Folder"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding Settings.OutputsDir}"
                                             ToolTip="Folder that contains the expected output files for each test"/>
                                    <Button Grid.Row="2" Grid.Column="2"
                                            Content="Browse…"
                                            Command="{Binding BrowseOutputsDirCommand}"
                                            ToolTip="Open folder browser to select the test outputs folder"
                                            Margin="6,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Save -->
                            <Button Content="  Save Settings  "
                                    Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Left"
                                    Padding="18,9"
                                    ToolTip="Persist all settings to disk"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Status bar                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding FooterText}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>

