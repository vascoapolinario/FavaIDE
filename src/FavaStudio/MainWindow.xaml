<Window x:Class="FavaStudio.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:FavaStudio.Models"
        Title="Fava Studio"
        Height="920"
        Width="1500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="◈" FontSize="18" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="4,0,8,0"/>
                    <TextBlock Text="Fava Studio" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,18,0"/>
                </StackPanel>

                <Menu Background="Transparent" DockPanel.Dock="Left" FontSize="14">
                    <MenuItem Header="Project">
                        <MenuItem Header="Create New Project" Command="{Binding CreateProjectCommand}"/>
                        <MenuItem Header="Open Project" Command="{Binding OpenProjectCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Settings">
                        <MenuItem Header="Open Settings" Command="{Binding OpenSettingsCommand}"/>
                        <MenuItem Header="Back to Editor" Command="{Binding BackToEditorCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Tools">
                        <MenuItem Header="Open Test Tool" Command="{Binding OpenToolsCommand}"/>
                        <MenuItem Header="Add Input (.fava)" Command="{Binding AddToolInputFileCommand}"/>
                        <MenuItem Header="Add Expected Output (.txt)" Command="{Binding AddToolExpectedOutputCommand}"/>
                        <MenuItem Header="Run Compare" Command="{Binding RunSelectedToolPairsCommand}"/>
                        <MenuItem Header="Clear Tool Pairs" Command="{Binding ClearToolPairsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Run">
                        <MenuItem Header="Run Current File" Command="{Binding RunCurrentCommand}"/>
                        <MenuItem Header="Save Current File" Command="{Binding SaveFileCommand}"/>
                        <MenuItem Header="Toggle Errors Panel" Command="{Binding ToggleDiagnosticsCommand}"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid Visibility="{Binding IsWorkspaceVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="180"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BgPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="10,7"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Background="{StaticResource BgPanelAltBrush}">
                            <TextBlock Text="PROJECT"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </Border>

                        <Border DockPanel.Dock="Top"
                                Padding="10,6"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding CurrentProjectDirectory}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TreeView ItemsSource="{Binding ProjectTree}"
                                  SelectedItemChanged="ProjectTree_OnSelectedItemChanged"
                                  Margin="4,4,4,0"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type local:ProjectNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="13"/>
                                        <TextBlock Text="{Binding Name}" FontSize="14"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Add">
                                                    <MenuItem Header="New Folder"
                                                              Command="{Binding PlacementTarget.DataContext.NewDirectoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="New Fava File"
                                                              Command="{Binding PlacementTarget.DataContext.NewFavaFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="New Text File"
                                                              Command="{Binding PlacementTarget.DataContext.NewTextFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>
                                                <MenuItem Header="Delete"
                                                          Command="{Binding PlacementTarget.DataContext.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              Background="{StaticResource BorderBrush}"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgPanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,5">
                        <TextBlock Text="{Binding CurrentFileName}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition MinWidth="0">
                                <ColumnDefinition.Style>
                                    <Style TargetType="ColumnDefinition">
                                        <Setter Property="Width" Value="300"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.ShowDiagnostics, ElementName=RootWindow}" Value="False">
                                                <Setter Property="Width" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ColumnDefinition.Style>
                            </ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <avalonedit:TextEditor Grid.Column="0"
                                               x:Name="Editor"
                                               FontFamily="Consolas"
                                               FontSize="14"
                                               ShowLineNumbers="True"
                                               Background="{StaticResource BgMainBrush}"
                                               Foreground="{StaticResource TextMainBrush}"/>

                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ResizeDirection="Columns"
                                      Background="{StaticResource BorderBrush}"/>

                        <Border Grid.Column="2"
                                Background="{StaticResource BgPanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0,0,0"
                                Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVisibility}}">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Padding="10,6"
                                        Background="{StaticResource BgPanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding DiagnosticsHeader}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </Border>
                                <ListBox ItemsSource="{Binding Diagnostics}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Margin="4,2">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="⚠ " Foreground="Orange"/>
                                                <Run Text="{Binding Severity}" Foreground="Orange"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding Line}" Foreground="{StaticResource TextMainBrush}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Column}" Foreground="{StaticResource TextMainBrush}"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding Message}" Foreground="{StaticResource TextMainBrush}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Row="2"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  Background="{StaticResource BorderBrush}"/>

                    <Border Grid.Row="3"
                            Background="{StaticResource BgPanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TabControl>
                            <TabItem Header="VM Output">
                                <TextBox x:Name="VmOutputBox"
                                         Text="{Binding VmOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Background="{StaticResource BgMainBrush}"
                                         Foreground="{StaticResource TextMainBrush}"
                                         BorderThickness="0"
                                         Padding="10"
                                         VerticalScrollBarVisibility="Auto"/>
                            </TabItem>
                            <TabItem Header="Constant Pool">
                                <TextBox Text="{Binding ConstantPoolOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Background="{StaticResource BgMainBrush}"
                                         Foreground="{StaticResource TextMainBrush}"
                                         BorderThickness="0"
                                         Padding="10"
                                         VerticalScrollBarVisibility="Auto"/>
                            </TabItem>
                            <TabItem Header="Instructions">
                                <TextBox Text="{Binding InstructionsOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Background="{StaticResource BgMainBrush}"
                                         Foreground="{StaticResource TextMainBrush}"
                                         BorderThickness="0"
                                         Padding="10"
                                         VerticalScrollBarVisibility="Auto"/>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding IsSettingsViewVisible, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20" Background="{StaticResource BgMainBrush}">
                    <StackPanel MaxWidth="860">
                        <DockPanel Margin="0,0,0,18">
                            <TextBlock DockPanel.Dock="Left" Text="Settings" FontSize="24" FontWeight="Bold"/>
                            <Button DockPanel.Dock="Right" Content="Back to Editor" Command="{Binding BackToEditorCommand}" />
                        </DockPanel>

                        <TextBlock Text="APPEARANCE"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12"
                                Margin="0,0,0,20"
                                Background="{StaticResource BgPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Terminal Output Mode" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1"
                                          Content="VM output only (exclude constant pool/instructions from main output)"
                                          IsChecked="{Binding ShowOutputOnly}" />
                            </Grid>
                        </Border>

                        <TextBlock Text="COMPILER"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12"
                                Margin="0,0,0,20"
                                Background="{StaticResource BgPanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Java Executable" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.JavaPath}"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Command="{Binding BrowseJavaPathCommand}" Margin="6,0,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Compiler Root" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.CompilerRoot}"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Browse…" Command="{Binding BrowseCompilerRootCommand}" Margin="6,0,0,0"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="ANTLR Jar" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Settings.AntlrJar}"/>
                                <Button Grid.Row="4" Grid.Column="2" Content="Browse…" Command="{Binding BrowseAntlrJarCommand}" Margin="6,0,0,0"/>
                            </Grid>
                        </Border>

                        <Button Content="Save Settings"
                                Command="{Binding SaveSettingsCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Left"
                                Padding="18,9"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Visibility="{Binding IsToolsViewVisible, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20" Background="{StaticResource BgMainBrush}">
                    <StackPanel MaxWidth="900">
                        <DockPanel Margin="0,0,0,18">
                            <TextBlock DockPanel.Dock="Left" Text="Tools • Test Compare" FontSize="24" FontWeight="Bold"/>
                            <Button DockPanel.Dock="Right" Content="Back to Editor" Command="{Binding BackToEditorCommand}" />
                        </DockPanel>

                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,12"
                                Margin="0,0,0,16"
                                Background="{StaticResource BgPanelBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Add Input (.fava)" Command="{Binding AddToolInputFileCommand}"/>
                                <Button Content="Add Expected Output (.txt)" Command="{Binding AddToolExpectedOutputCommand}"/>
                                <Button Content="Run Compare" Command="{Binding RunSelectedToolPairsCommand}" Style="{StaticResource AccentButton}"/>
                                <Button Content="Clear" Command="{Binding ClearToolPairsCommand}"/>
                                <CheckBox Content="Compare VM + constant pool + instructions"
                                          IsChecked="{Binding ToolCompareFullOutput}"
                                          Margin="14,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding ToolTestPairs}"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Input (.fava)" Binding="{Binding InputFile}" Width="*"/>
                                <DataGridTextColumn Header="Expected (.txt)" Binding="{Binding ExpectedOutputFile}" Width="*"/>
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding FooterText}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
